{
  "schemaVersion": 1,
  "plugin": "codex-voice-notifier-jk",
  "defaultEvent": "done",
  "audioRoot": "audio",
  "voiceDirection": "Address the user as 博士. The default voice style is 温柔 JK: gentle, youthful, bright, caring, emotional, natural, and clear. Avoid flat mechanical narration and exaggerated acting.",
  "events": {
    "done": {
      "description": "A substantive Codex response or task finished successfully."
    },
    "failed": {
      "description": "Codex reports a failed command, blocked task, or unrecovered error."
    },
    "need_input": {
      "description": "Codex needs the user to make a choice or provide missing information."
    },
    "attention": {
      "description": "Codex has an important warning or notable finding."
    },
    "checkpoint": {
      "description": "Codex produced a useful intermediate result."
    },
    "clarify": {
      "description": "Codex wants to discuss or clarify the user's intent before continuing."
    },
    "understood": {
      "description": "Codex acknowledges that it understands the user's idea or intent."
    },
    "encourage": {
      "description": "Codex encourages the user after a setback or retry."
    },
    "praise": {
      "description": "Codex positively acknowledges a strong idea from the user."
    }
  },
  "selection": {
    "strategy": "priority",
    "fallbackSystemSound": "Asterisk"
  },
  "cleanupPolicy": {
    "neverDeleteUserAudioAutomatically": true,
    "transcodedCacheTtlDays": 7,
    "deleteOrphansOnlyWhenExplicit": true
  },
  "items": [
